{
  "name": "mindnotes-pro",
  "version": "1.3.2",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "A modern browser-based note-taking app with handwriting support",
  "homepage": "https://11suixing11.github.io/mindnotes-pro/",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:web": "tsc && vite build --base=/mindnotes-pro/",
    "preview": "vite preview",
    "predeploy": "npm run build:web",
    "deploy": "gh-pages -d dist",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "bundle:analyze": "node ./scripts/optimize-bundle.js",
    "bundle:budget": "node ./scripts/check-bundle-budget.js",
    "doctor:android": "powershell -ExecutionPolicy Bypass -File ./scripts/doctor-android-env.ps1",
    "doctor:tauri": "powershell -ExecutionPolicy Bypass -File ./scripts/doctor-tauri-env.ps1",
    "electron:dev": "vite && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:preview": "npm run build && electron ."
  },
  "keywords": [
    "notes",
    "handwriting",
    "canvas",
    "productivity"
  ],
  "author": "11suixing11",
  "license": "MIT",
  "build": {
    "appId": "com.mindnotes.pro",
    "productName": "MindNotes Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.18",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.35",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vitest": "^4.1.0"
  }
}
